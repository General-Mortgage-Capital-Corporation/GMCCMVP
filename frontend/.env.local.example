# Copy this file to .env.local and fill in your values.
# Next.js reads .env.local automatically — never commit .env.local to git.

# ── RentCast ──────────────────────────────────────────────────────────────────
# Used server-side for property search and marketing search.
# Get a key at: https://app.rentcast.io/app/api-access
RENTCAST_API_KEY=your_rentcast_key_here

# ── Google Places ─────────────────────────────────────────────────────────────
# Used server-side for address autocomplete and the interactive map widget.
# Enable "Places API" and "Maps JavaScript API" in Google Cloud Console.
# Restrict the key to your Vercel deployment domain in production.
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# ── Gemini ────────────────────────────────────────────────────────────────────
# Used server-side for email subject/body suggestions (/api/suggest-email).
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ── Python matching microservice ──────────────────────────────────────────────
# URL of the Flask backend (server.py).
# Local dev:  http://localhost:5001
# Production: https://your-python-vercel-project.vercel.app
PYTHON_SERVICE_URL=http://localhost:5001

# ── Firebase (for flier generation sign-in) ───────────────────────────────────
# Used client-side for Firebase Auth (LOs sign in before generating PDF fliers).
# Found in Firebase Console → Project Settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here

# ── Azure AD / MSAL (GMCC SSO) ────────────────────────────────────────────────
# Used client-side for GMCC staff sign-in via Microsoft.
# Found in Azure Portal → App registrations → your app → Overview.
NEXT_PUBLIC_AZURE_CLIENT_ID=your_azure_client_id_here
NEXT_PUBLIC_AZURE_TENANT_ID=your_azure_tenant_id_here
