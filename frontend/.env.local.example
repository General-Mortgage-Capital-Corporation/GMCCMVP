# Copy this file to .env.local and fill in your values.
# Next.js reads .env.local automatically — never commit it to git.

# RentCast API key (https://app.rentcast.io/app/api-access)
RENTCAST_API_KEY=your_rentcast_key_here

# Google Places API key (for address autocomplete + map widget)
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# URL of the Python matching microservice (default: local Flask dev server)
# Change this in production to point at your deployed Python service.
PYTHON_SERVICE_URL=http://localhost:5001
