# Copy this file to .env and fill in your values.
# This file is read by the Python matching microservice (server.py).
# Never commit .env to git.

# ── Gemini ────────────────────────────────────────────────────────────────────
# Used for AI talking points generation (/api/explain endpoint).
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ── RentCast / Google (reference only) ───────────────────────────────────────
# These keys are NOT used by the Python service — all RentCast and Google API
# calls are made from the Next.js layer. Listed here for reference only.
# RENTCAST_API_KEY=
# GOOGLE_PLACES_API_KEY=
